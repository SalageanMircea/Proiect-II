<Page x:Class="Restaurant_Management.Views.LoginPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      Background="#B19149">

    <Grid>
        <Border Width="420"
                Padding="30"
                CornerRadius="20"
                Background="Black"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">

            <StackPanel>

                <Image Source="/Assets/Logo.png"
                       Width="100"
                       Height="100"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,15"/>

                <TextBlock Text="Restaurant Manager"
                           FontSize="30"
                           FontWeight="Bold"
                           Foreground="White"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,10"/>

                <TextBlock Text="Autentificare utilizator"
                           FontSize="18"
                           Foreground="Gray"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,25"/>

                <TextBlock Text="Nume utilizator"
                           Foreground="White"
                           FontSize="14"
                           Margin="0,0,0,5"/>

                <TextBox x:Name="UsernameTextBox"
                         Height="35"
                         FontSize="14"
                         Padding="8"
                         Margin="0,0,0,15"/>

                <TextBlock Text="Parola"
                           Foreground="White"
                           FontSize="14"
                           Margin="0,0,0,5"/>

                <PasswordBox x:Name="PasswordBox"
                             Height="35"
                             FontSize="14"
                             Padding="8"
                             Margin="0,0,0,15"/>

                <TextBlock x:Name="ErrorTextBlock"
                           Text=""
                           Foreground="Red"
                           TextWrapping="Wrap"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,15"/>

                <Button Content="Logare"
                        Height="45"
                        Width="140"
                        HorizontalAlignment="Center"
                        Click="LoginButton_Click"
                        Background="#B19149"
                        Foreground="White"
                        FontWeight="Bold"
                        BorderThickness="0"
                        />

                <TextBlock Text="Acces pe bază de rol: Manager / Ospatar / Bucatar"
                           HorizontalAlignment="Center"
                           Foreground="DarkGray"
                           FontStyle="Italic"
                           TextWrapping="Wrap"
                           Margin="0,15,0,0"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>