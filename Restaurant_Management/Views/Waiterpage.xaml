<Page
    x:Class="Restaurant_Management.Views.WaiterPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="#0F172A">

    <Page.Resources>
        <SolidColorBrush x:Key="CardBackgroundBrush" Color="#111827"/>
        <SolidColorBrush x:Key="CardBorderBrush" Color="#334155"/>
        <SolidColorBrush x:Key="HeaderBackgroundBrush" Color="#1E293B"/>
        <SolidColorBrush x:Key="PrimaryTextBrush" Color="#F8FAFC"/>
        <SolidColorBrush x:Key="SecondaryTextBrush" Color="#CBD5E1"/>
        <SolidColorBrush x:Key="MutedTextBrush" Color="#94A3B8"/>
        <SolidColorBrush x:Key="InputBackgroundBrush" Color="#0F172A"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#2563EB"/>
        <SolidColorBrush x:Key="SecondaryButtonBrush" Color="#334155"/>
        <SolidColorBrush x:Key="DangerButtonBrush" Color="#DC2626"/>
        <SolidColorBrush x:Key="SuccessButtonBrush" Color="#16A34A"/>

        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource CardBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="20"/>
        </Style>

        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}"/>
        </Style>

        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="CornerRadius" Value="8"/>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource SecondaryButtonBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource CardBorderBrush}"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="CornerRadius" Value="8"/>
        </Style>

        <Style x:Key="DangerButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource DangerButtonBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource DangerButtonBrush}"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="CornerRadius" Value="8"/>
        </Style>

        <Style x:Key="AddButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="CornerRadius" Value="8"/>
        </Style>
    </Page.Resources>

    <Grid Padding="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="390"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock
                    Text="Waiter Panel"
                    FontSize="30"
                    FontWeight="Bold"
                    Foreground="{StaticResource PrimaryTextBrush}"
                    VerticalAlignment="Center"/>

                <TextBlock
                    x:Name="WelcomeText"
                    FontSize="16"
                    Foreground="{StaticResource SecondaryTextBrush}"
                    VerticalAlignment="Center"
                    Margin="20,0,0,0"/>
            </StackPanel>

            <Button
                Grid.Column="1"
                Content="Logout"
                Click="LogoutButton_Click"
                Style="{StaticResource DangerButtonStyle}"
                VerticalAlignment="Center"/>
        </Grid>

        <!-- Menu + selected order -->
        <Grid Grid.Row="1" ColumnSpacing="20" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.6*"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>

            <!-- Restaurant Menu -->
            <Border Grid.Column="0" Style="{StaticResource CardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock
                        Grid.Row="0"
                        Text="Meniu restaurant"
                        Style="{StaticResource SectionTitleStyle}"
                        Margin="0,0,0,12"/>

                    <ListView
                        Grid.Row="1"
                        x:Name="MenuListView"
                        SelectionMode="None"
                        Background="Transparent"
                        BorderThickness="0">

                        <ListView.Header>
                            <Grid Padding="12,10" Background="{StaticResource HeaderBackgroundBrush}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2*"/>
                                    <ColumnDefinition Width="1.3*"/>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="90"/>
                                    <ColumnDefinition Width="100"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0" Text="Produs" FontWeight="SemiBold" Foreground="{StaticResource PrimaryTextBrush}"/>
                                <TextBlock Grid.Column="1" Text="Categorie" FontWeight="SemiBold" Foreground="{StaticResource PrimaryTextBrush}"/>
                                <TextBlock Grid.Column="2" Text="Pret" FontWeight="SemiBold" Foreground="{StaticResource PrimaryTextBrush}"/>
                                <TextBlock Grid.Column="3" Text="Cant." FontWeight="SemiBold" Foreground="{StaticResource PrimaryTextBrush}"/>
                                <TextBlock Grid.Column="4" Text="Actiune" FontWeight="SemiBold" Foreground="{StaticResource PrimaryTextBrush}"/>
                            </Grid>
                        </ListView.Header>

                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Border
                                    BorderBrush="{StaticResource CardBorderBrush}"
                                    BorderThickness="0,0,0,1"
                                    Padding="12,10">

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="2*"/>
                                            <ColumnDefinition Width="1.3*"/>
                                            <ColumnDefinition Width="100"/>
                                            <ColumnDefinition Width="90"/>
                                            <ColumnDefinition Width="100"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock
                                            Grid.Column="0"
                                            Text="{Binding Name}"
                                            Foreground="{StaticResource PrimaryTextBrush}"
                                            VerticalAlignment="Center"/>

                                        <TextBlock
                                            Grid.Column="1"
                                            Text="{Binding Category}"
                                            Foreground="{StaticResource SecondaryTextBrush}"
                                            VerticalAlignment="Center"/>

                                        <TextBlock
                                            Grid.Column="2"
                                            Text="{Binding PriceText}"
                                            Foreground="{StaticResource PrimaryTextBrush}"
                                            VerticalAlignment="Center"/>

                                        <NumberBox
                                            Grid.Column="3"
                                            Width="70"
                                            Minimum="1"
                                            Maximum="50"
                                            Value="{Binding Quantity, Mode=TwoWay}"
                                            SpinButtonPlacementMode="Compact"
                                            Background="{StaticResource InputBackgroundBrush}"
                                            Foreground="{StaticResource PrimaryTextBrush}"
                                            BorderBrush="{StaticResource CardBorderBrush}"/>

                                        <Button
                                            Grid.Column="4"
                                            Content="Adauga"
                                            Click="AddMenuItemToOrder_Click"
                                            Style="{StaticResource AddButtonStyle}"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>

            <!-- Selected Order -->
            <Border Grid.Column="1" Style="{StaticResource CardStyle}">
                <StackPanel Spacing="14">
                    <TextBlock
                        Text="Comanda client"
                        Style="{StaticResource SectionTitleStyle}"/>

                    <StackPanel>
                        <TextBlock
                            Text="Masa"
                            Style="{StaticResource LabelStyle}"/>

                        <NumberBox
                            x:Name="TableNumberBox"
                            Minimum="1"
                            Maximum="50"
                            Value="1"
                            Width="120"
                            SpinButtonPlacementMode="Compact"
                            Background="{StaticResource InputBackgroundBrush}"
                            Foreground="{StaticResource PrimaryTextBrush}"
                            BorderBrush="{StaticResource CardBorderBrush}"/>
                    </StackPanel>

                    <StackPanel>
                        <TextBlock
                            Text="Produse selectate"
                            Style="{StaticResource LabelStyle}"/>

                        <TextBox
                            x:Name="OrderTextBox"
                            PlaceholderText="Produsele selectate apar aici..."
                            Height="120"
                            AcceptsReturn="True"
                            TextWrapping="Wrap"
                            Background="{StaticResource InputBackgroundBrush}"
                            Foreground="{StaticResource PrimaryTextBrush}"
                            PlaceholderForeground="{StaticResource MutedTextBrush}"
                            BorderBrush="{StaticResource CardBorderBrush}"/>
                    </StackPanel>

                    <Grid ColumnSpacing="10" Margin="0,6,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Button
                            Grid.Column="0"
                            Content="Send Order"
                            Click="SendOrderButton_Click"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Height="42"
                            HorizontalAlignment="Stretch"/>

                        <Button
                            Grid.Column="1"
                            Content="Goleste"
                            Click="ClearOrderButton_Click"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Height="42"
                            HorizontalAlignment="Stretch"/>

                        <Button
                            Grid.Column="2"
                            Content="Refresh"
                            Click="RefreshButton_Click"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Height="42"
                            HorizontalAlignment="Stretch"/>
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>

        <!-- My Orders -->
        <Border Grid.Row="2" Style="{StaticResource CardStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock
                    Grid.Row="0"
                    Text="My Orders"
                    Style="{StaticResource SectionTitleStyle}"
                    Margin="0,0,0,12"/>

                <ListView
                    Grid.Row="1"
                    x:Name="OrdersListView"
                    SelectionMode="None"
                    Background="Transparent"
                    BorderThickness="0">

                    <ListView.Header>
                        <Grid Padding="12,10" Background="{StaticResource HeaderBackgroundBrush}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="130"/>
                                <ColumnDefinition Width="160"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0" Text="Order ID" FontWeight="SemiBold" Foreground="{StaticResource PrimaryTextBrush}"/>
                            <TextBlock Grid.Column="1" Text="Table" FontWeight="SemiBold" Foreground="{StaticResource PrimaryTextBrush}"/>
                            <TextBlock Grid.Column="2" Text="Details" FontWeight="SemiBold" Foreground="{StaticResource PrimaryTextBrush}"/>
                            <TextBlock Grid.Column="3" Text="Status" FontWeight="SemiBold" Foreground="{StaticResource PrimaryTextBrush}"/>
                            <TextBlock Grid.Column="4" Text="Sent At" FontWeight="SemiBold" Foreground="{StaticResource PrimaryTextBrush}"/>
                        </Grid>
                    </ListView.Header>

                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Border
                                BorderBrush="{StaticResource CardBorderBrush}"
                                BorderThickness="0,0,0,1"
                                Padding="12,10">

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="130"/>
                                        <ColumnDefinition Width="160"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock
                                        Grid.Column="0"
                                        Text="{Binding OrderId}"
                                        Foreground="{StaticResource PrimaryTextBrush}"
                                        VerticalAlignment="Center"/>

                                    <TextBlock
                                        Grid.Column="1"
                                        Text="{Binding TableNumber}"
                                        Foreground="{StaticResource PrimaryTextBrush}"
                                        VerticalAlignment="Center"/>

                                    <TextBlock
                                        Grid.Column="2"
                                        Text="{Binding Details}"
                                        Foreground="{StaticResource PrimaryTextBrush}"
                                        TextWrapping="Wrap"
                                        VerticalAlignment="Center"/>

                                    <Border
                                        Grid.Column="3"
                                        CornerRadius="12"
                                        Padding="10,4"
                                        Background="{Binding StatusColor}"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Center">

                                        <TextBlock
                                            Text="{Binding Status}"
                                            FontSize="12"
                                            FontWeight="SemiBold"
                                            Foreground="White"/>
                                    </Border>

                                    <TextBlock
                                        Grid.Column="4"
                                        Text="{Binding SentAt}"
                                        FontSize="12"
                                        Foreground="{StaticResource SecondaryTextBrush}"
                                        VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </Border>
    </Grid>
</Page>