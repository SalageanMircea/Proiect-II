<Page
    x:Class="Restaurant_Management.Views.WaiterPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Restaurant_Management.Views"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid Padding="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

      
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,20">
            <TextBlock Text="🍽️ Waiter Panel" FontSize="28" FontWeight="Bold" VerticalAlignment="Center"/>
            <TextBlock x:Name="WelcomeText" FontSize="16" Foreground="Gray" 
                       VerticalAlignment="Center" Margin="20,0,0,0"/>
        </StackPanel>


        <Border Grid.Row="1" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                CornerRadius="8" Padding="20" Margin="0,0,0,20"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,15,0" VerticalAlignment="Center">
                    <TextBlock Text="Table No." FontSize="12" Foreground="Gray" Margin="0,0,0,4"/>
                    <NumberBox x:Name="TableNumberBox" Minimum="1" Maximum="50" Value="1"
                               SpinButtonPlacementMode="Compact" Width="100"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="0,0,15,0">
                    <TextBlock Text="Order Details" FontSize="12" Foreground="Gray" Margin="0,0,0,4"/>
                    <TextBox x:Name="OrderTextBox"
                             PlaceholderText="e.g. 2x Steak, 1x Caesar Salad, 3x Water..."
                             Height="60" AcceptsReturn="True" TextWrapping="Wrap"/>
                </StackPanel>

                <Button Grid.Column="2" x:Name="SendOrderButton" Content="📤 Send Order"
                        Click="SendOrderButton_Click"
                        Style="{StaticResource AccentButtonStyle}"
                        VerticalAlignment="Bottom" Height="40" Margin="0,0,10,0"/>

                <Button Grid.Column="3" x:Name="LogoutButton" Content="Logout"
                        Click="LogoutButton_Click"
                        VerticalAlignment="Bottom" Height="40"/>
            </Grid>
        </Border>

      
        <Border Grid.Row="2" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                CornerRadius="8" Padding="20"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="My Orders" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,12"/>

                <ListView Grid.Row="1" x:Name="OrdersListView" SelectionMode="None">
                    <ListView.Header>
                        <Grid Padding="12,8" Background="{ThemeResource SubtleFillColorSecondaryBrush}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="130"/>
                                <ColumnDefinition Width="160"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Order ID" FontWeight="SemiBold" FontSize="13"/>
                            <TextBlock Grid.Column="1" Text="Table" FontWeight="SemiBold" FontSize="13"/>
                            <TextBlock Grid.Column="2" Text="Details" FontWeight="SemiBold" FontSize="13"/>
                            <TextBlock Grid.Column="3" Text="Status" FontWeight="SemiBold" FontSize="13"/>
                            <TextBlock Grid.Column="4" Text="Sent At" FontWeight="SemiBold" FontSize="13"/>
                        </Grid>
                    </ListView.Header>
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid Padding="12,10" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" BorderThickness="0,0,0,1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="130"/>
                                    <ColumnDefinition Width="160"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{Binding OrderId}" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" Text="{Binding TableNumber}" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="2" Text="{Binding Details}" TextWrapping="Wrap" VerticalAlignment="Center"/>
                                <Border Grid.Column="3" CornerRadius="12" Padding="10,4"
                                        Background="{Binding StatusColor}" HorizontalAlignment="Left" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Status}" FontSize="12" FontWeight="SemiBold" Foreground="White"/>
                                </Border>
                                <TextBlock Grid.Column="4" Text="{Binding SentAt}" FontSize="12" Foreground="Gray" VerticalAlignment="Center"/>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </Border>
    </Grid>
</Page>
