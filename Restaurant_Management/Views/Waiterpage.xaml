<Page
    x:Class="Restaurant_Management.Views.WaiterPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid Padding="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="320"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal">
                <TextBlock Text="🍽️ Waiter Panel"
                           FontSize="28"
                           FontWeight="Bold"
                           VerticalAlignment="Center"/>

                <TextBlock x:Name="WelcomeText"
                           FontSize="16"
                           Foreground="Gray"
                           VerticalAlignment="Center"
                           Margin="20,0,0,0"/>
            </StackPanel>

            <Button Grid.Column="1"
                    Content="Logout"
                    Click="LogoutButton_Click"
                    VerticalAlignment="Center"/>
        </Grid>

        <!-- Menu + selected order -->
        <Grid Grid.Row="1" ColumnSpacing="20" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.5*"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>

            <!-- Restaurant Menu -->
            <Border Grid.Column="0"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="20">

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="Meniu restaurant"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Margin="0,0,0,12"/>

                    <ListView Grid.Row="1"
                              x:Name="MenuListView"
                              SelectionMode="None">

                        <ListView.Header>
                            <Grid Padding="12,8"
                                  Background="{ThemeResource SubtleFillColorSecondaryBrush}">

                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2*"/>
                                    <ColumnDefinition Width="1.3*"/>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="90"/>
                                    <ColumnDefinition Width="100"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0" Text="Produs" FontWeight="SemiBold"/>
                                <TextBlock Grid.Column="1" Text="Categorie" FontWeight="SemiBold"/>
                                <TextBlock Grid.Column="2" Text="Pret" FontWeight="SemiBold"/>
                                <TextBlock Grid.Column="3" Text="Cant." FontWeight="SemiBold"/>
                                <TextBlock Grid.Column="4" Text="Actiune" FontWeight="SemiBold"/>
                            </Grid>
                        </ListView.Header>

                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                                        BorderThickness="0,0,0,1"
                                        Padding="12,8">

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="2*"/>
                                            <ColumnDefinition Width="1.3*"/>
                                            <ColumnDefinition Width="100"/>
                                            <ColumnDefinition Width="90"/>
                                            <ColumnDefinition Width="100"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Column="0"
                                                   Text="{Binding Name}"
                                                   VerticalAlignment="Center"/>

                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding Category}"
                                                   Foreground="Gray"
                                                   VerticalAlignment="Center"/>

                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding PriceText}"
                                                   VerticalAlignment="Center"/>

                                        <NumberBox Grid.Column="3"
                                                   Width="70"
                                                   Minimum="1"
                                                   Maximum="50"
                                                   Value="{Binding Quantity, Mode=TwoWay}"
                                                   SpinButtonPlacementMode="Compact"/>

                                        <Button Grid.Column="4"
                                                Content="Adauga"
                                                Click="AddMenuItemToOrder_Click"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>

            <!-- Selected Order -->
            <Border Grid.Column="1"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="20">

                <StackPanel Spacing="12">
                    <TextBlock Text="Comanda client"
                               FontSize="18"
                               FontWeight="SemiBold"/>

                    <StackPanel>
                        <TextBlock Text="Masa"
                                   FontSize="12"
                                   Foreground="Gray"
                                   Margin="0,0,0,4"/>

                        <NumberBox x:Name="TableNumberBox"
                                   Minimum="1"
                                   Maximum="50"
                                   Value="1"
                                   Width="120"
                                   SpinButtonPlacementMode="Compact"/>
                    </StackPanel>

                    <StackPanel>
                        <TextBlock Text="Produse selectate"
                                   FontSize="12"
                                   Foreground="Gray"
                                   Margin="0,0,0,4"/>

                        <TextBox x:Name="OrderTextBox"
                                 PlaceholderText="Produsele selectate apar aici..."
                                 Height="120"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <Button Content="📤 Send Order"
                                Click="SendOrderButton_Click"
                                Style="{StaticResource AccentButtonStyle}"
                                Height="40"/>

                        <Button Content="Goleste"
                                Click="ClearOrderButton_Click"
                                Height="40"/>

                        <Button Content="Refresh"
                                Click="RefreshButton_Click"
                                Height="40"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <!-- My Orders -->
        <Border Grid.Row="2"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="20">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="My Orders"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Margin="0,0,0,12"/>

                <ListView Grid.Row="1"
                          x:Name="OrdersListView"
                          SelectionMode="None">

                    <ListView.Header>
                        <Grid Padding="12,8"
                              Background="{ThemeResource SubtleFillColorSecondaryBrush}">

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="130"/>
                                <ColumnDefinition Width="160"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0" Text="Order ID" FontWeight="SemiBold"/>
                            <TextBlock Grid.Column="1" Text="Table" FontWeight="SemiBold"/>
                            <TextBlock Grid.Column="2" Text="Details" FontWeight="SemiBold"/>
                            <TextBlock Grid.Column="3" Text="Status" FontWeight="SemiBold"/>
                            <TextBlock Grid.Column="4" Text="Sent At" FontWeight="SemiBold"/>
                        </Grid>
                    </ListView.Header>

                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                                    BorderThickness="0,0,0,1"
                                    Padding="12,10">

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="130"/>
                                        <ColumnDefinition Width="160"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0"
                                               Text="{Binding OrderId}"
                                               VerticalAlignment="Center"/>

                                    <TextBlock Grid.Column="1"
                                               Text="{Binding TableNumber}"
                                               VerticalAlignment="Center"/>

                                    <TextBlock Grid.Column="2"
                                               Text="{Binding Details}"
                                               TextWrapping="Wrap"
                                               VerticalAlignment="Center"/>

                                    <Border Grid.Column="3"
                                            CornerRadius="12"
                                            Padding="10,4"
                                            Background="{Binding StatusColor}"
                                            HorizontalAlignment="Left"
                                            VerticalAlignment="Center">

                                        <TextBlock Text="{Binding Status}"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"
                                                   Foreground="White"/>
                                    </Border>

                                    <TextBlock Grid.Column="4"
                                               Text="{Binding SentAt}"
                                               FontSize="12"
                                               Foreground="Gray"
                                               VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </Border>
    </Grid>
</Page>