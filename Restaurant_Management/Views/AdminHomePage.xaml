<Page
    x:Class="Restaurant_Management.Views.AdminHomePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="#B19149">

    <ScrollViewer>
        <StackPanel Padding="30" Spacing="25">
            <TextBlock
                Text="Panou Administrare"
                FontSize="32"
                FontWeight="Bold"/>

            <TextBlock
                Text="Alege una dintre optiunile de administrare"
                FontSize="18"
                Foreground="Black"/>

            <Grid ColumnSpacing="20" RowSpacing="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Row="0" Grid.Column="0" Height="100" Click="MenuButton_Click">
                    <StackPanel>
                        <TextBlock Text="Gestionarea meniului" FontSize="20" FontWeight="SemiBold"/>
                        <TextBlock Text="Adauga, editeaza si sterge preparate"/>
                    </StackPanel>
                </Button>

                <Button Grid.Row="0" Grid.Column="1" Height="100" Click="TablesButton_Click">
                    <StackPanel>
                        <TextBlock Text="Gestionarea meselor" FontSize="20" FontWeight="SemiBold"/>
                        <TextBlock Text="Organizare si starea meselor"/>
                    </StackPanel>
                </Button>

                <Button Grid.Row="1" Grid.Column="0" Height="100" Click="OrdersButton_Click">
                    <StackPanel>
                        <TextBlock Text="Gestionarea comenzilor" FontSize="20" FontWeight="SemiBold"/>
                        <TextBlock Text="Vizualizare și administrare comenzi"/>
                    </StackPanel>
                </Button>

                <Button Grid.Row="1" Grid.Column="1" Height="100" Click="StockButton_Click">
                    <StackPanel>
                        <TextBlock Text="Gestionarea stocului" FontSize="20" FontWeight="SemiBold"/>
                        <TextBlock Text="Produse si cantitati disponibile"/>
                    </StackPanel>
                </Button>

                <Button Grid.Row="2" Grid.Column="0" Height="100" Click="ShoppingButton_Click">
                    <StackPanel>
                        <TextBlock Text="Lista cumparaturi / aprovizionare" FontSize="20" FontWeight="SemiBold"/>
                        <TextBlock Text="Necesitati pentru aprovizionare"/>
                    </StackPanel>
                </Button>

                <Button Grid.Row="2" Grid.Column="1" Height="100" Click="EmployeesButton_Click">
                    <StackPanel>
                        <TextBlock Text="Program angajati" FontSize="20" FontWeight="SemiBold"/>
                        <TextBlock Text="Gestionarea turelor și programului"/>
                    </StackPanel>
                </Button>
            </Grid>

            <Button
                Content="Dashboard / Statistici"
                Height="90"
                FontSize="20"
                FontWeight="SemiBold"
                Click="DashboardButton_Click"/>

            <Button
                Content="Delogare"
                Height="45"
                HorizontalAlignment="Left"
                Click="LogoutButton_Click"/>
        </StackPanel>
    </ScrollViewer>
</Page>