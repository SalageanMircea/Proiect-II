<Page
    x:Class="Restaurant_Management.Views.MenuManagementPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid Padding="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Spacing="8" Margin="0,0,0,25">
            <TextBlock Text="Gestionarea Meniului"
                       FontSize="30"
                       FontWeight="Bold"/>

            <TextBlock Text="Aici managerul poate adauga, edita si sterge produsele din meniu."
                       FontSize="18"
                       Foreground="Gray"/>
        </StackPanel>

        <!-- Add / Edit Form -->
        <Border Grid.Row="1"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="20"
                Margin="0,0,0,20">

            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="1.5*"/>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="Nume produs"
                               FontSize="12"
                               Foreground="Gray"
                               Margin="0,0,0,4"/>

                    <TextBox x:ConnectionId='12' x:Name="NameBox"
                             PlaceholderText="Ex: Pizza Margherita"/>
                </StackPanel>

                <StackPanel Grid.Column="1">
                    <TextBlock Text="Categorie"
                               FontSize="12"
                               Foreground="Gray"
                               Margin="0,0,0,4"/>

                    <TextBox x:ConnectionId='11' x:Name="CategoryBox"
                             PlaceholderText="Ex: Pizza"/>
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <TextBlock Text="Pret"
                               FontSize="12"
                               Foreground="Gray"
                               Margin="0,0,0,4"/>

                    <TextBox x:ConnectionId='10' x:Name="PriceBox"
                             PlaceholderText="Ex: 32.00"/>
                </StackPanel>

                <CheckBox x:ConnectionId='6' Grid.Column="3"
                          x:Name="AvailableCheckBox"
                          Content="Disponibil"
                          IsChecked="True"
                          VerticalAlignment="Bottom"/>

                <Button x:ConnectionId='7' Grid.Column="4"
                        x:Name="SaveButton"
                        Content="Salveaza"
                                                
                        Style="{StaticResource AccentButtonStyle}"
                        VerticalAlignment="Bottom"/>

                <Button x:ConnectionId='8' Grid.Column="5"
                        x:Name="ClearButton"
                        Content="Curata"
                                                 
                        VerticalAlignment="Bottom"/>

                <Button x:ConnectionId='9' Grid.Column="6"
                        Content="Inapoi"
                                                
                        VerticalAlignment="Bottom"/>
            </Grid>
        </Border>

        <!-- Menu List -->
        <Border Grid.Row="2"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="20">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="Produse din meniu"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Margin="0,0,0,12"/>

                <ListView x:ConnectionId='2' Grid.Row="1"
                          x:Name="MenuListView"
                          SelectionMode="None">

                    <ListView.Header>
                        <Grid Padding="12,8"
                              Background="{ThemeResource SubtleFillColorSecondaryBrush}">

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="70"/>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="1.5*"/>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="130"/>
                                <ColumnDefinition Width="180"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                       Text="ID"
                                       FontWeight="SemiBold"/>

                            <TextBlock Grid.Column="1"
                                       Text="Produs"
                                       FontWeight="SemiBold"/>

                            <TextBlock Grid.Column="2"
                                       Text="Categorie"
                                       FontWeight="SemiBold"/>

                            <TextBlock Grid.Column="3"
                                       Text="Pret"
                                       FontWeight="SemiBold"/>

                            <TextBlock Grid.Column="4"
                                       Text="Status"
                                       FontWeight="SemiBold"/>

                            <TextBlock Grid.Column="5"
                                       Text="Actiuni"
                                       FontWeight="SemiBold"/>
                        </Grid>
                    </ListView.Header>

                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                                    BorderThickness="0,0,0,1"
                                    Padding="12,10">

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="70"/>
                                        <ColumnDefinition Width="2*"/>
                                        <ColumnDefinition Width="1.5*"/>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="130"/>
                                        <ColumnDefinition Width="180"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0"
                                               Text="{Binding MenuId}"
                                               VerticalAlignment="Center"/>

                                    <TextBlock Grid.Column="1"
                                               Text="{Binding Name}"
                                               VerticalAlignment="Center"/>

                                    <TextBlock Grid.Column="2"
                                               Text="{Binding Category}"
                                               VerticalAlignment="Center"
                                               Foreground="Gray"/>

                                    <TextBlock Grid.Column="3"
                                               Text="{Binding PriceText}"
                                               VerticalAlignment="Center"/>

                                    <TextBlock Grid.Column="4"
                                               Text="{Binding AvailabilityText}"
                                               VerticalAlignment="Center"/>

                                    <StackPanel Grid.Column="5"
                                                Orientation="Horizontal"
                                                Spacing="8">

                                        <Button x:ConnectionId='4' Content="Edit"
                                                                        />

                                        <Button x:ConnectionId='5' Content="Sterge"
                                                                          />
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </Border>
    </Grid>
</Page>

