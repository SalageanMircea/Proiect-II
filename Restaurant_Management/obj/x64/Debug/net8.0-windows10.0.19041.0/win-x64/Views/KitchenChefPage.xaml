<Page
    x:Class="Restaurant_Management.Views.KitchenChefPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="#0F172A">

    <Page.Resources>
        <SolidColorBrush x:Key="PageBackgroundBrush" Color="#0F172A"/>
        <SolidColorBrush x:Key="CardBackgroundBrush" Color="#111827"/>
        <SolidColorBrush x:Key="CardBorderBrush" Color="#334155"/>
        <SolidColorBrush x:Key="HeaderBackgroundBrush" Color="#1E293B"/>
        <SolidColorBrush x:Key="PrimaryTextBrush" Color="#F8FAFC"/>
        <SolidColorBrush x:Key="SecondaryTextBrush" Color="#CBD5E1"/>
        <SolidColorBrush x:Key="MutedTextBrush" Color="#94A3B8"/>

        <SolidColorBrush x:Key="BlueButtonBrush" Color="#2563EB"/>
        <SolidColorBrush x:Key="YellowButtonBrush" Color="#CA8A04"/>
        <SolidColorBrush x:Key="GreenButtonBrush" Color="#16A34A"/>
        <SolidColorBrush x:Key="RedButtonBrush" Color="#DC2626"/>
        <SolidColorBrush x:Key="GrayButtonBrush" Color="#334155"/>

        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource CardBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="20"/>
        </Style>

        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}"/>
        </Style>

        <Style x:Key="TableHeaderTextStyle" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}"/>
        </Style>

        <Style x:Key="TableTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="MutedTableTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource SecondaryTextBrush}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="RefreshButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource BlueButtonBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource BlueButtonBrush}"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="CornerRadius" Value="8"/>
        </Style>

        <Style x:Key="LogoutButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource RedButtonBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource RedButtonBrush}"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="CornerRadius" Value="8"/>
        </Style>

        <Style x:Key="ReceivedButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource BlueButtonBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource BlueButtonBrush}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="CornerRadius" Value="8"/>
        </Style>

        <Style x:Key="PreparingButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource YellowButtonBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource YellowButtonBrush}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="CornerRadius" Value="8"/>
        </Style>

        <Style x:Key="DoneButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource GreenButtonBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource GreenButtonBrush}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="CornerRadius" Value="8"/>
        </Style>
    </Page.Resources>

    <Grid Padding="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock
                    Text="Kitchen Chef Panel"
                    FontSize="30"
                    FontWeight="Bold"
                    Foreground="{StaticResource PrimaryTextBrush}"
                    VerticalAlignment="Center"/>

                <TextBlock x:ConnectionId='13'
                    x:Name="WelcomeText"
                    FontSize="16"
                    Foreground="{StaticResource SecondaryTextBrush}"
                    VerticalAlignment="Center"
                    Margin="20,0,0,0"/>
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10">
                <Button x:ConnectionId='11'
                    Content="Refresh"
                                               
                    Style="{StaticResource RefreshButtonStyle}"/>

                <Button x:ConnectionId='12'
                    Content="Logout"
                                              
                    Style="{StaticResource LogoutButtonStyle}"/>
            </StackPanel>
        </Grid>

        <!-- Filters -->
        <StackPanel
            Grid.Row="1"
            Orientation="Horizontal"
            Spacing="18"
            Margin="0,0,0,18">

            <TextBlock
                Text="Filter:"
                Foreground="{StaticResource PrimaryTextBrush}"
                VerticalAlignment="Center"
                FontWeight="SemiBold"/>

            <RadioButton x:ConnectionId='7'
                x:Name="FilterAll"
                Content="All"
                IsChecked="True"
                                    
                GroupName="StatusFilter"
                Foreground="{StaticResource PrimaryTextBrush}"/>

            <RadioButton x:ConnectionId='8'
                x:Name="FilterReceived"
                Content="Received"
                                    
                GroupName="StatusFilter"
                Foreground="{StaticResource PrimaryTextBrush}"/>

            <RadioButton x:ConnectionId='9'
                x:Name="FilterPreparing"
                Content="Preparing"
                                    
                GroupName="StatusFilter"
                Foreground="{StaticResource PrimaryTextBrush}"/>

            <RadioButton x:ConnectionId='10'
                x:Name="FilterDone"
                Content="Done"
                                    
                GroupName="StatusFilter"
                Foreground="{StaticResource PrimaryTextBrush}"/>
        </StackPanel>

        <!-- Orders -->
        <Border Grid.Row="2" Style="{StaticResource CardStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock
                    Grid.Row="0"
                    Text="Incoming Orders"
                    Style="{StaticResource SectionTitleStyle}"
                    Margin="0,0,0,12"/>

                <ListView x:ConnectionId='2'
                    Grid.Row="1"
                    x:Name="OrdersListView"
                    SelectionMode="None"
                    Background="Transparent"
                    BorderThickness="0">

                    <ListView.Header>
                        <Grid Padding="12,10" Background="{StaticResource HeaderBackgroundBrush}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="130"/>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="250"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0" Text="Order ID" Style="{StaticResource TableHeaderTextStyle}"/>
                            <TextBlock Grid.Column="1" Text="Table" Style="{StaticResource TableHeaderTextStyle}"/>
                            <TextBlock Grid.Column="2" Text="Waiter" Style="{StaticResource TableHeaderTextStyle}"/>
                            <TextBlock Grid.Column="3" Text="Details" Style="{StaticResource TableHeaderTextStyle}"/>
                            <TextBlock Grid.Column="4" Text="Status" Style="{StaticResource TableHeaderTextStyle}"/>
                            <TextBlock Grid.Column="5" Text="Sent At" Style="{StaticResource TableHeaderTextStyle}"/>
                            <TextBlock Grid.Column="6" Text="Update Status" Style="{StaticResource TableHeaderTextStyle}"/>
                        </Grid>
                    </ListView.Header>

                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Border
                                BorderBrush="{StaticResource CardBorderBrush}"
                                BorderThickness="0,0,0,1"
                                Padding="12,10">

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="130"/>
                                        <ColumnDefinition Width="160"/>
                                        <ColumnDefinition Width="250"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock
                                        Grid.Column="0"
                                        Text="{Binding OrderId}"
                                        Style="{StaticResource TableTextStyle}"/>

                                    <TextBlock
                                        Grid.Column="1"
                                        Text="{Binding TableNumber}"
                                        Style="{StaticResource TableTextStyle}"/>

                                    <TextBlock
                                        Grid.Column="2"
                                        Text="{Binding WaiterName}"
                                        TextTrimming="CharacterEllipsis"
                                        Style="{StaticResource TableTextStyle}"/>

                                    <TextBlock
                                        Grid.Column="3"
                                        Text="{Binding Details}"
                                        TextWrapping="Wrap"
                                        Margin="0,0,10,0"
                                        Style="{StaticResource TableTextStyle}"/>

                                    <Border
                                        Grid.Column="4"
                                        CornerRadius="12"
                                        Padding="10,4"
                                        Background="{Binding StatusColor}"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Center">

                                        <TextBlock
                                            Text="{Binding Status}"
                                            FontSize="12"
                                            FontWeight="SemiBold"
                                            Foreground="White"/>
                                    </Border>

                                    <TextBlock
                                        Grid.Column="5"
                                        Text="{Binding SentAt}"
                                        FontSize="12"
                                        Style="{StaticResource MutedTableTextStyle}"/>

                                    <StackPanel
                                        Grid.Column="6"
                                        Orientation="Horizontal"
                                        Spacing="6"
                                        VerticalAlignment="Center">

                                        <Button x:ConnectionId='4'
                                            Content="Received"
                                            Tag="Received"
                                                                            
                                            Style="{StaticResource ReceivedButtonStyle}"/>

                                        <Button x:ConnectionId='5'
                                            Content="Preparing"
                                            Tag="Preparing"
                                                                            
                                            Style="{StaticResource PreparingButtonStyle}"/>

                                        <Button x:ConnectionId='6'
                                            Content="Done"
                                            Tag="Done"
                                                                            
                                            Style="{StaticResource DoneButtonStyle}"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </Border>
    </Grid>
</Page>

