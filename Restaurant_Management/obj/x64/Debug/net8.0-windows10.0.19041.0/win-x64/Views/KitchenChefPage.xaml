<Page
    x:Class="Restaurant_Management.Views.KitchenChefPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Restaurant_Management.Views"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid Padding="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Orientation="Horizontal">
                <TextBlock Text="👨‍🍳 Kitchen Chef Panel" FontSize="28" FontWeight="Bold" VerticalAlignment="Center"/>
                <TextBlock x:ConnectionId='21' x:Name="WelcomeText" FontSize="16" Foreground="Gray"
                           VerticalAlignment="Center" Margin="20,0,0,0"/>
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10">
                <Button x:ConnectionId='19' Content="🔄 Refresh"                             VerticalAlignment="Center"/>
                <Button x:ConnectionId='20' Content="Logout"                            VerticalAlignment="Center"/>
            </StackPanel>
        </Grid>

        <!-- Status Filter -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="10" Margin="0,0,0,16">
            <TextBlock Text="Filter:" VerticalAlignment="Center" FontWeight="SemiBold"/>
            <RadioButton x:ConnectionId='15' x:Name="FilterAll" Content="All" IsChecked="True"                      GroupName="StatusFilter"/>
            <RadioButton x:ConnectionId='16' x:Name="FilterReceived" Content="Received"                      GroupName="StatusFilter"/>
            <RadioButton x:ConnectionId='17' x:Name="FilterPreparing" Content="Preparing"                      GroupName="StatusFilter"/>
            <RadioButton x:ConnectionId='18' x:Name="FilterDone" Content="Done"                      GroupName="StatusFilter"/>
        </StackPanel>

        <!-- Orders List -->
        <Border Grid.Row="2" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                CornerRadius="8" Padding="20"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Incoming Orders" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,12"/>

                <ListView x:ConnectionId='2' Grid.Row="1" x:Name="OrdersListView" SelectionMode="None">
                    <ListView.Header>
                        <Grid Padding="12,8" Background="{ThemeResource SubtleFillColorSecondaryBrush}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="130"/>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="200"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Order ID" FontWeight="SemiBold" FontSize="13"/>
                            <TextBlock Grid.Column="1" Text="Table" FontWeight="SemiBold" FontSize="13"/>
                            <TextBlock Grid.Column="2" Text="Waiter" FontWeight="SemiBold" FontSize="13"/>
                            <TextBlock Grid.Column="3" Text="Details" FontWeight="SemiBold" FontSize="13"/>
                            <TextBlock Grid.Column="4" Text="Status" FontWeight="SemiBold" FontSize="13"/>
                            <TextBlock Grid.Column="5" Text="Sent At" FontWeight="SemiBold" FontSize="13"/>
                            <TextBlock Grid.Column="6" Text="Update Status" FontWeight="SemiBold" FontSize="13"/>
                        </Grid>
                    </ListView.Header>
                    <ListView.ItemTemplate>
                        <DataTemplate                                 >
                            <Grid x:ConnectionId='4' Padding="12,10" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" BorderThickness="0,0,0,1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="130"/>
                                    <ColumnDefinition Width="160"/>
                                    <ColumnDefinition Width="200"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock x:ConnectionId='5' Grid.Column="0"                         VerticalAlignment="Center"/>
                                <TextBlock x:ConnectionId='6' Grid.Column="1"                             VerticalAlignment="Center"/>
                                <TextBlock x:ConnectionId='7' Grid.Column="2"                            VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                <TextBlock x:ConnectionId='8' Grid.Column="3"                         TextWrapping="Wrap" VerticalAlignment="Center" Margin="0,0,10,0"/>

                                <Border x:ConnectionId='9' Grid.Column="4" CornerRadius="12" Padding="10,4"
                                                                          HorizontalAlignment="Left" VerticalAlignment="Center">
                                    <TextBlock x:ConnectionId='14'                        FontSize="12" FontWeight="SemiBold" Foreground="White"/>
                                </Border>

                                <TextBlock x:ConnectionId='10' Grid.Column="5"                        FontSize="12" Foreground="Gray" VerticalAlignment="Center"/>

                                <!-- Status Buttons -->
                                <StackPanel Grid.Column="6" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                    <Button x:ConnectionId='11' Content="Received"                       
                                                                      FontSize="11" Padding="8,4"/>
                                    <Button x:ConnectionId='12' Content="Preparing"                       
                                                                       FontSize="11" Padding="8,4"/>
                                    <Button x:ConnectionId='13' Content="Done"                       
                                                                  FontSize="11" Padding="8,4"
                                            Style="{StaticResource AccentButtonStyle}"/>
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </Border>
    </Grid>
</Page>

