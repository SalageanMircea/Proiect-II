<Page
    x:Class="Restaurant_Management.Views.KitchenChefPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid Padding="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal">
                <TextBlock Text="👨‍🍳 Kitchen Chef Panel"
                           FontSize="28"
                           FontWeight="Bold"
                           VerticalAlignment="Center"/>

                <TextBlock x:ConnectionId='13' x:Name="WelcomeText"
                           FontSize="16"
                           Foreground="Gray"
                           VerticalAlignment="Center"
                           Margin="20,0,0,0"/>
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10">
                <Button x:ConnectionId='11' Content="🔄 Refresh"
                                                   />

                <Button x:ConnectionId='12' Content="Logout"
                                                  />
            </StackPanel>
        </Grid>

        <!-- Filters -->
        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    Spacing="10"
                    Margin="0,0,0,16">

            <TextBlock Text="Filter:"
                       VerticalAlignment="Center"
                       FontWeight="SemiBold"/>

            <RadioButton x:ConnectionId='7' x:Name="FilterAll"
                         Content="All"
                         IsChecked="True"
                                             
                         GroupName="StatusFilter"/>

            <RadioButton x:ConnectionId='8' x:Name="FilterReceived"
                         Content="Received"
                                             
                         GroupName="StatusFilter"/>

            <RadioButton x:ConnectionId='9' x:Name="FilterPreparing"
                         Content="Preparing"
                                             
                         GroupName="StatusFilter"/>

            <RadioButton x:ConnectionId='10' x:Name="FilterDone"
                         Content="Done"
                                             
                         GroupName="StatusFilter"/>
        </StackPanel>

        <!-- Orders -->
        <Border Grid.Row="2"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="20">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="Incoming Orders"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Margin="0,0,0,12"/>

                <ListView x:ConnectionId='2' Grid.Row="1"
                          x:Name="OrdersListView"
                          SelectionMode="None">

                    <ListView.Header>
                        <Grid Padding="12,8"
                              Background="{ThemeResource SubtleFillColorSecondaryBrush}">

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="130"/>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="230"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0" Text="Order ID" FontWeight="SemiBold"/>
                            <TextBlock Grid.Column="1" Text="Table" FontWeight="SemiBold"/>
                            <TextBlock Grid.Column="2" Text="Waiter" FontWeight="SemiBold"/>
                            <TextBlock Grid.Column="3" Text="Details" FontWeight="SemiBold"/>
                            <TextBlock Grid.Column="4" Text="Status" FontWeight="SemiBold"/>
                            <TextBlock Grid.Column="5" Text="Sent At" FontWeight="SemiBold"/>
                            <TextBlock Grid.Column="6" Text="Update Status" FontWeight="SemiBold"/>
                        </Grid>
                    </ListView.Header>

                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                                    BorderThickness="0,0,0,1"
                                    Padding="12,10">

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="130"/>
                                        <ColumnDefinition Width="160"/>
                                        <ColumnDefinition Width="230"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0"
                                               Text="{Binding OrderId}"
                                               VerticalAlignment="Center"/>

                                    <TextBlock Grid.Column="1"
                                               Text="{Binding TableNumber}"
                                               VerticalAlignment="Center"/>

                                    <TextBlock Grid.Column="2"
                                               Text="{Binding WaiterName}"
                                               TextTrimming="CharacterEllipsis"
                                               VerticalAlignment="Center"/>

                                    <TextBlock Grid.Column="3"
                                               Text="{Binding Details}"
                                               TextWrapping="Wrap"
                                               VerticalAlignment="Center"
                                               Margin="0,0,10,0"/>

                                    <Border Grid.Column="4"
                                            CornerRadius="12"
                                            Padding="10,4"
                                            Background="{Binding StatusColor}"
                                            HorizontalAlignment="Left"
                                            VerticalAlignment="Center">

                                        <TextBlock Text="{Binding Status}"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"
                                                   Foreground="White"/>
                                    </Border>

                                    <TextBlock Grid.Column="5"
                                               Text="{Binding SentAt}"
                                               FontSize="12"
                                               Foreground="Gray"
                                               VerticalAlignment="Center"/>

                                    <StackPanel Grid.Column="6"
                                                Orientation="Horizontal"
                                                Spacing="6"
                                                VerticalAlignment="Center">

                                        <Button x:ConnectionId='4' Content="Received"
                                                Tag="{Binding OrderId}"
                                                                         
                                                FontSize="11"
                                                Padding="8,4"/>

                                        <Button x:ConnectionId='5' Content="Preparing"
                                                Tag="{Binding OrderId}"
                                                                          
                                                FontSize="11"
                                                Padding="8,4"/>

                                        <Button x:ConnectionId='6' Content="Done"
                                                Tag="{Binding OrderId}"
                                                                     
                                                FontSize="11"
                                                Padding="8,4"
                                                Style="{StaticResource AccentButtonStyle}"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </Border>
    </Grid>
</Page>

