<Page
    x:Class="Restaurant_Management.Views.AdminHomePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="#0F172A">

    <Page.Resources>
        <SolidColorBrush x:Key="PageBackgroundBrush" Color="#0F172A"/>
        <SolidColorBrush x:Key="CardBackgroundBrush" Color="#1E293B"/>
        <SolidColorBrush x:Key="CardBorderBrush" Color="#334155"/>
        <SolidColorBrush x:Key="PrimaryTextBrush" Color="#F8FAFC"/>
        <SolidColorBrush x:Key="SecondaryTextBrush" Color="#CBD5E1"/>
        <SolidColorBrush x:Key="GrayButtonBrush" Color="#334155"/>

        <Style x:Key="AdminButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="110"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="VerticalAlignment" Value="Stretch"/>
            <Setter Property="Background" Value="{StaticResource CardBackgroundBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource CardBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="20"/>
        </Style>

        <Style x:Key="AdminButtonTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}"/>
            <Setter Property="TextAlignment" Value="Center"/>
        </Style>

        <Style x:Key="AdminButtonDescriptionStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="{StaticResource SecondaryTextBrush}"/>
            <Setter Property="TextAlignment" Value="Center"/>
        </Style>
    </Page.Resources>

    <ScrollViewer Background="{StaticResource PageBackgroundBrush}">
        <StackPanel Padding="30" Spacing="25">

            <TextBlock
                Text="Panou Administrare"
                FontSize="32"
                FontWeight="Bold"
                Foreground="{StaticResource PrimaryTextBrush}"/>

            <TextBlock
                Text="Alege una dintre optiunile de administrare"
                FontSize="18"
                Foreground="{StaticResource SecondaryTextBrush}"/>

            <Grid ColumnSpacing="20" RowSpacing="12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Gestionare meniu -->
                <Button x:ConnectionId='3'
                    Grid.Row="0"
                    Grid.Column="0"
                    Style="{StaticResource AdminButtonStyle}"
                    Tag="Menu"
                                             >

                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="6">
                        <TextBlock
                            Text="Gestionarea meniului"
                            Style="{StaticResource AdminButtonTitleStyle}"/>

                        <TextBlock
                            Text="Adauga, editeaza si sterge preparate"
                            Style="{StaticResource AdminButtonDescriptionStyle}"/>
                    </StackPanel>
                </Button>

                <!-- Gestionare comenzi -->
                <Button x:ConnectionId='4'
                    Grid.Row="0"
                    Grid.Column="1"
                    Style="{StaticResource AdminButtonStyle}"
                    Tag="Orders"
                                             >

                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="6">
                        <TextBlock
                            Text="Gestionarea comenzilor"
                            Style="{StaticResource AdminButtonTitleStyle}"/>

                        <TextBlock
                            Text="Vizualizare si administrare comenzi"
                            Style="{StaticResource AdminButtonDescriptionStyle}"/>
                    </StackPanel>
                </Button>

                <!-- Lista cumparaturi -->
                <Button x:ConnectionId='5'
                    Grid.Row="1"
                    Grid.Column="0"
                    Style="{StaticResource AdminButtonStyle}"
                    Tag="Shopping"
                                             >

                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="6">
                        <TextBlock
                            Text="Lista cumparaturi / aprovizionare"
                            Style="{StaticResource AdminButtonTitleStyle}"/>

                        <TextBlock
                            Text="Necesitati pentru aprovizionare"
                            Style="{StaticResource AdminButtonDescriptionStyle}"/>
                    </StackPanel>
                </Button>

                <!-- Program angajati -->
                <Button x:ConnectionId='6'
                    Grid.Row="1"
                    Grid.Column="1"
                    Style="{StaticResource AdminButtonStyle}"
                    Tag="Employees"
                                             >

                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="6">
                        <TextBlock
                            Text="Program angajati"
                            Style="{StaticResource AdminButtonTitleStyle}"/>

                        <TextBlock
                            Text="Gestionarea turelor si programului"
                            Style="{StaticResource AdminButtonDescriptionStyle}"/>
                    </StackPanel>
                </Button>

                <!-- Gestionare angajati -->
                <Button x:ConnectionId='7'
                    Grid.Row="2"
                    Grid.Column="0"
                    Grid.ColumnSpan="2"
                    Style="{StaticResource AdminButtonStyle}"
                    Tag="EmployeesManagement"
                                             >

                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="6">
                        <TextBlock
                            Text="Gestionare angajati"
                            Style="{StaticResource AdminButtonTitleStyle}"/>

                        <TextBlock
                            Text="Adauga, editeaza si sterge angajati"
                            Style="{StaticResource AdminButtonDescriptionStyle}"/>
                    </StackPanel>
                </Button>
            </Grid>

            <Button x:ConnectionId='2'
                Content="Delogare"
                Height="45"
                Width="120"
                HorizontalAlignment="Left"
                Tag="Logout"
                                         
                Background="{StaticResource GrayButtonBrush}"
                Foreground="White"
                BorderBrush="{StaticResource CardBorderBrush}"
                BorderThickness="1"/>

        </StackPanel>
    </ScrollViewer>
</Page>

