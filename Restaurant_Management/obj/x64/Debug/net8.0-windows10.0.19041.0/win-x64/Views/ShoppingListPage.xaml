<Page
    x:Class="Restaurant_Management.Views.ShoppingListPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="#0F172A">

    <Page.Resources>
        <SolidColorBrush x:Key="CardBackgroundBrush" Color="#111827"/>
        <SolidColorBrush x:Key="CardBorderBrush" Color="#334155"/>
        <SolidColorBrush x:Key="HeaderBackgroundBrush" Color="#1E293B"/>
        <SolidColorBrush x:Key="PrimaryTextBrush" Color="#F8FAFC"/>
        <SolidColorBrush x:Key="SecondaryTextBrush" Color="#CBD5E1"/>
        <SolidColorBrush x:Key="MutedTextBrush" Color="#94A3B8"/>
        <SolidColorBrush x:Key="InputBackgroundBrush" Color="#0F172A"/>

        <SolidColorBrush x:Key="BlueButtonBrush" Color="#2563EB"/>
        <SolidColorBrush x:Key="YellowButtonBrush" Color="#CA8A04"/>
        <SolidColorBrush x:Key="GreenButtonBrush" Color="#16A34A"/>
        <SolidColorBrush x:Key="RedButtonBrush" Color="#DC2626"/>
        <SolidColorBrush x:Key="GrayButtonBrush" Color="#334155"/>

        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource CardBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="20"/>
        </Style>

        <Style x:Key="PageTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="30"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}"/>
        </Style>

        <Style x:Key="PageSubtitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="Foreground" Value="{StaticResource SecondaryTextBrush}"/>
        </Style>

        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}"/>
        </Style>

        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>

        <Style x:Key="InputStyle" TargetType="TextBox">
            <Setter Property="Height" Value="40"/>
            <Setter Property="Background" Value="{StaticResource InputBackgroundBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}"/>
            <Setter Property="PlaceholderForeground" Value="{StaticResource MutedTextBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource CardBorderBrush}"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="CornerRadius" Value="8"/>
        </Style>

        <Style x:Key="BlueButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource BlueButtonBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource BlueButtonBrush}"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="CornerRadius" Value="8"/>
        </Style>

        <Style x:Key="YellowButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource YellowButtonBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource YellowButtonBrush}"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="CornerRadius" Value="8"/>
        </Style>

        <Style x:Key="GreenButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource GreenButtonBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource GreenButtonBrush}"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="CornerRadius" Value="8"/>
        </Style>

        <Style x:Key="RedButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource RedButtonBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource RedButtonBrush}"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="CornerRadius" Value="8"/>
        </Style>

        <Style x:Key="GrayButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource GrayButtonBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource CardBorderBrush}"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="CornerRadius" Value="8"/>
        </Style>

        <Style x:Key="TableHeaderTextStyle" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="TableTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </Page.Resources>

    <Grid Padding="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Spacing="8">
                <TextBlock
                    Text="Lista cumparaturi / aprovizionare"
                    Style="{StaticResource PageTitleStyle}"/>

                <TextBlock
                    Text="Aici managerul poate administra produsele care trebuie cumparate pentru restaurant."
                    Style="{StaticResource PageSubtitleStyle}"/>
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                <Button x:ConnectionId='17'
                    Content="Refresh"
                                               
                    Style="{StaticResource BlueButtonStyle}"/>

                <Button x:ConnectionId='18'
                    Content="Inapoi"
                                            
                    Style="{StaticResource GrayButtonStyle}"/>
            </StackPanel>
        </Grid>

        <!-- Form -->
        <Border
            Grid.Row="1"
            Style="{StaticResource CardStyle}"
            Margin="0,0,0,20">

            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock
                        Text="Produs"
                        Style="{StaticResource LabelStyle}"/>

                    <TextBox x:ConnectionId='16'
                        x:Name="NameBox"
                        PlaceholderText="Ex: Cartofi"
                        Style="{StaticResource InputStyle}"/>
                </StackPanel>

                <StackPanel Grid.Column="1">
                    <TextBlock
                        Text="Cantitate"
                        Style="{StaticResource LabelStyle}"/>

                    <TextBox x:ConnectionId='15'
                        x:Name="QuantityBox"
                        PlaceholderText="Ex: 10"
                        Style="{StaticResource InputStyle}"/>
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <TextBlock
                        Text="Unitate"
                        Style="{StaticResource LabelStyle}"/>

                    <TextBox x:ConnectionId='14'
                        x:Name="UnitBox"
                        PlaceholderText="Ex: kg / buc / litri"
                        Style="{StaticResource InputStyle}"/>
                </StackPanel>

                <CheckBox x:ConnectionId='11'
                    Grid.Column="3"
                    x:Name="PurchasedCheckBox"
                    Content="Cumparat"
                    Foreground="{StaticResource PrimaryTextBrush}"
                    VerticalAlignment="Bottom"
                    Margin="0,0,4,4"/>

                <Button x:ConnectionId='12'
                    Grid.Column="4"
                    x:Name="SaveButton"
                    Content="Salveaza"
                                            
                    Style="{StaticResource BlueButtonStyle}"
                    VerticalAlignment="Bottom"/>

                <Button x:ConnectionId='13'
                    Grid.Column="5"
                    Content="Curata"
                                             
                    Style="{StaticResource GrayButtonStyle}"
                    VerticalAlignment="Bottom"/>
            </Grid>
        </Border>

        <!-- Filter -->
        <Border
            Grid.Row="2"
            Style="{StaticResource CardStyle}"
            Margin="0,0,0,20">

            <StackPanel Orientation="Horizontal" Spacing="18">
                <TextBlock
                    Text="Filtru:"
                    Foreground="{StaticResource PrimaryTextBrush}"
                    FontWeight="SemiBold"
                    VerticalAlignment="Center"/>

                <RadioButton x:ConnectionId='8'
                    x:Name="FilterAll"
                    Content="Toate"
                    IsChecked="True"
                                        
                    GroupName="ShoppingFilter"
                    Foreground="{StaticResource PrimaryTextBrush}"/>

                <RadioButton x:ConnectionId='9'
                    x:Name="FilterNeeded"
                    Content="Necesar"
                                        
                    GroupName="ShoppingFilter"
                    Foreground="{StaticResource PrimaryTextBrush}"/>

                <RadioButton x:ConnectionId='10'
                    x:Name="FilterPurchased"
                    Content="Cumparat"
                                        
                    GroupName="ShoppingFilter"
                    Foreground="{StaticResource PrimaryTextBrush}"/>
            </StackPanel>
        </Border>

        <!-- List -->
        <Border Grid.Row="3" Style="{StaticResource CardStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock
                    Grid.Row="0"
                    Text="Produse pentru aprovizionare"
                    Style="{StaticResource SectionTitleStyle}"
                    Margin="0,0,0,12"/>

                <ListView x:ConnectionId='2'
                    Grid.Row="1"
                    x:Name="ShoppingListView"
                    SelectionMode="None"
                    Background="Transparent"
                    BorderThickness="0">

                    <ListView.Header>
                        <Grid Padding="12,10" Background="{StaticResource HeaderBackgroundBrush}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="360"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0" Text="ID" Style="{StaticResource TableHeaderTextStyle}"/>
                            <TextBlock Grid.Column="1" Text="Produs" Style="{StaticResource TableHeaderTextStyle}"/>
                            <TextBlock Grid.Column="2" Text="Cantitate" Style="{StaticResource TableHeaderTextStyle}"/>
                            <TextBlock Grid.Column="3" Text="Status" Style="{StaticResource TableHeaderTextStyle}"/>
                            <TextBlock Grid.Column="4" Text="Creat la" Style="{StaticResource TableHeaderTextStyle}"/>
                            <TextBlock Grid.Column="5" Text="Actiuni" Style="{StaticResource TableHeaderTextStyle}"/>
                        </Grid>
                    </ListView.Header>

                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Border
                                BorderBrush="{StaticResource CardBorderBrush}"
                                BorderThickness="0,0,0,1"
                                Padding="12,10">

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="2*"/>
                                        <ColumnDefinition Width="160"/>
                                        <ColumnDefinition Width="140"/>
                                        <ColumnDefinition Width="160"/>
                                        <ColumnDefinition Width="360"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock
                                        Grid.Column="0"
                                        Text="{Binding ShoppingItemId}"
                                        Style="{StaticResource TableTextStyle}"/>

                                    <TextBlock
                                        Grid.Column="1"
                                        Text="{Binding Name}"
                                        Style="{StaticResource TableTextStyle}"/>

                                    <TextBlock
                                        Grid.Column="2"
                                        Text="{Binding QuantityText}"
                                        Style="{StaticResource TableTextStyle}"/>

                                    <Border
                                        Grid.Column="3"
                                        CornerRadius="12"
                                        Padding="10,4"
                                        Background="{Binding StatusColor}"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Center">

                                        <TextBlock
                                            Text="{Binding StatusText}"
                                            FontSize="12"
                                            FontWeight="SemiBold"
                                            Foreground="White"/>
                                    </Border>

                                    <TextBlock
                                        Grid.Column="4"
                                        Text="{Binding CreatedAt}"
                                        FontSize="12"
                                        Foreground="{StaticResource SecondaryTextBrush}"
                                        VerticalAlignment="Center"/>

                                    <StackPanel
                                        Grid.Column="5"
                                        Orientation="Horizontal"
                                        Spacing="8"
                                        VerticalAlignment="Center">

                                        <Button x:ConnectionId='4'
                                            Content="Edit"
                                                                    
                                            Style="{StaticResource YellowButtonStyle}"/>

                                        <Button x:ConnectionId='5'
                                            Content="Necesar"
                                                                          
                                            Style="{StaticResource BlueButtonStyle}"/>

                                        <Button x:ConnectionId='6'
                                            Content="Cumparat"
                                                                             
                                            Style="{StaticResource GreenButtonStyle}"/>

                                        <Button x:ConnectionId='7'
                                            Content="Sterge"
                                                                      
                                            Style="{StaticResource RedButtonStyle}"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </Border>
    </Grid>
</Page>

